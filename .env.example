# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DATABASE=jobdetector

# Email Configuration (Gmail SMTP)
EMAIL_USERNAME=your_email@gmail.com
EMAIL_APP_PASSWORD=your_app_password_here

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
BASE_URL=https://jobdetector.blackrice.top
ADMIN_EMAIL=your_admin_email@gmail.com

# ── Personal Career Digest ────────────────────────────────────────────────────
# Email address to receive the daily digest (usually same as EMAIL_USERNAME)
RECIPIENT_EMAIL=your_personal_email@gmail.com

# AI Provider: "gemini" | "minimax" | "keyword" (keyword = no API needed)
AI_PROVIDER=gemini

# Google Gemini API Key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# MiniMax API Key (alternative to Gemini)
MINIMAX_API_KEY=your_minimax_api_key_here
